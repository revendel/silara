---
/**
 * Footer component.
 * WordPress equivalent: footer.php / get_footer().
 *
 * Large screen: inactive (icon-only) logo left + legal/nav links right.
 * Small screen: stacked column layout.
 */
import Logo from "./Logo.astro";
---

<footer
  class="site-footer"
  transition:name="site-footer"
  transition:animate="none"
>
  <Logo variant="inactive" />

  <nav class="site-footer__links" aria-label="Footer navigation">
    <ul class="site-footer__link-list" role="list">
      <li>
        <a
          href="https://wa.me/917439285007"
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__link">Order at +91 7439285007</a
        >
      </li>
      <li><a href="/terms" class="site-footer__link">T&amp;C</a></li>
      <li><a href="/privacy" class="site-footer__link">Privacy</a></li>
      <li><span class="site-footer__link">GSTIN: 19CTHPM0710P1ZC</span></li>
      <li>
        <span class="site-footer__link"
          >Silara Foods is a brand by Silara Enterprises</span
        >
      </li>
    </ul>
  </nav>

  <p class="site-footer__legal">
    Looking to import next generation foods? Reach us at
    <a href="mailto:contact@silara.org">contact@silara.org</a>
    for any feedback or inquiries.
  </p>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--scale-8);
    height: var(--scale-9);
    border-bottom: var(--scale-2) solid var(--lines);
    background-color: var(--base);
    flex-shrink: 0;
  }

  .site-footer__link-list {
    display: flex;
    align-items: center;
    gap: var(--scale-6);
    list-style: none;
  }

  .site-footer__link {
    font-size: var(--scale-5); /* 13px — reduced in Figma */
    line-height: var(--scale-6);
    padding: var(--scale-4);
    transition: opacity 0.15s ease;
  }

  a.site-footer__link:hover {
    opacity: 0.5;
  }

  /* ── Tablet/mobile: stacked column ── */
  .site-footer__legal {
    display: none;
  }

  /* ── Fluid desktop (1024–1439px) ── */
  @media (min-width: 1024px) and (max-width: 1439px) {
    .site-footer {
      padding: 0 var(--scale-6);
    }
  }

  @media (max-width: 1023px) {
    .site-footer {
      height: auto;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--scale-6);
      padding: var(--scale-10) var(--scale-7) var(--scale-9);
      border-bottom: none;
    }

    .site-footer__link-list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--scale-4);
    }

    .site-footer__link {
      padding-left: 0;
      padding-right: 0;
    }

    .site-footer__legal {
      display: block;
      font-size: var(--scale-5);
      line-height: var(--scale-5);
      font-weight: 400;
      max-width: 268px;
    }

    .site-footer__legal a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  }
</style>
