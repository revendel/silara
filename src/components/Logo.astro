---
/**
 * Logo component.
 * WordPress equivalent: custom logo template part (logo.php).
 *
 * The icon is four 16.25 × 16.25 px semicircles arranged in an
 * alternating left/right helix pattern across a 32.5 × 65 px grid.
 *
 * Variants:
 *   default  — full logo (icon + wordmark), large
 *   smaller  — full logo, reduced size
 *   inactive — icon only, 50 % opacity (used in footer)
 */
interface Props {
  variant?: 'default' | 'smaller' | 'inactive';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;
---

<a
  href="/"
  class:list={['logo', `logo--${variant}`, className]}
  aria-label="Silara SuperFoods — home"
>
  <!-- Four-semicircle helix icon -->
  <div class="logo__icon" aria-hidden="true">
    <span class="logo__dot logo__dot--tl"></span>
    <span class="logo__dot logo__dot--tr"></span>
    <span class="logo__dot logo__dot--bl"></span>
    <span class="logo__dot logo__dot--br"></span>
  </div>

  {variant !== 'inactive' && (
    <div class="logo__wordmark">
      <span class="logo__brand">Silara</span>
      <span class="logo__superfoods">SuperFoods</span>
      <sup class="logo__tm">TM</sup>
    </div>
  )}
</a>

<style>
  /* ── Base ── */
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--scale-5);
    height: 65px;
    color: var(--primary);
    text-decoration: none;
    flex-shrink: 0;
    position: relative;
  }

  /* ── Icon: 4 semicircles in alternating helix ── */
  .logo__icon {
    position: relative;
    width: 32.5px;
    height: 65px;
    flex-shrink: 0;
  }

  .logo__dot {
    position: absolute;
    width: 16.25px;
    height: 16.25px;
    background-color: var(--primary);
  }

  /* Left-facing (rounded on left side) */
  .logo__dot--tl { top: 0px;      left: 0px;      border-radius: 100px 0 0 100px; }
  .logo__dot--bl { top: 32.5px;   left: 0px;      border-radius: 100px 0 0 100px; }

  /* Right-facing (rounded on right side) */
  .logo__dot--tr { top: 16.25px;  left: 16.25px;  border-radius: 0 100px 100px 0; }
  .logo__dot--br { top: 48.75px;  left: 16.25px;  border-radius: 0 100px 100px 0; }

  /* ── Wordmark ── */
  .logo__wordmark {
    display: flex;
    align-items: flex-end;
    gap: var(--scale-3);
    line-height: 1;
    position: relative;
  }

  .logo__brand {
    font-size: var(--scale-7);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
  }

  .logo__superfoods {
    font-size: var(--scale-7);
    font-weight: 400;
    line-height: 1;
  }

  .logo__tm {
    font-size: var(--scale-5);
    font-weight: 400;
    line-height: 1;
    position: absolute;
    top: -2px;
    right: -18px;
  }

  /* ── Variants ── */
  .logo--inactive {
    opacity: 0.5;
    height: 39px;
  }

  /* Inactive icon: 9.75px semicircles in a 19.5×39px grid (Figma values) */
  .logo--inactive .logo__icon {
    width: 19.5px;
    height: 39px;
  }

  .logo--inactive .logo__dot {
    width: 9.75px;
    height: 9.75px;
  }

  .logo--inactive .logo__dot--tl { top: 0px;     left: 0px;    }
  .logo--inactive .logo__dot--bl { top: 19.5px;  left: 0px;    }
  .logo--inactive .logo__dot--tr { top: 9.75px;  left: 9.75px; }
  .logo--inactive .logo__dot--br { top: 29.25px; left: 9.75px; }

  .logo--smaller .logo__brand,
  .logo--smaller .logo__superfoods {
    font-size: var(--scale-6);
  }

  /* ── Tablet/mobile: shrink default logo to smaller variant sizing ── */
  @media (max-width: 1023px) {
    .logo--default .logo__brand,
    .logo--default .logo__superfoods {
      font-size: var(--scale-6);
    }
  }
</style>
