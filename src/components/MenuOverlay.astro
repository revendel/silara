---
/**
 * MenuOverlay component — mobile/tablet only.
 * WordPress equivalent: mobile-menu.php template part.
 *
 * Full-screen white sheet that drops down below the header.
 * Header stays on top (z-index: 80). This overlay is z-index: 50.
 * The header "Other Pages" button text toggles to "Close" when open.
 */
const navLinks = [
  { href: '/',            label: 'Home'        },
  { href: '/mission',     label: 'Mission'     },
  { href: '/our-product', label: 'Our Product' },
  { href: '/the-future',  label: 'The Future'  },
  { href: '/contact',     label: 'Contact'     },
  { href: '/terms',       label: 'T&C'         },
  { href: '/privacy',     label: 'Privacy'     },
];
---

<div
  class="menu-overlay"
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <nav class="menu-overlay__nav" aria-label="Mobile navigation">
    <ul class="menu-overlay__list" role="list">
      {navLinks.map(link => (
        <li class="menu-overlay__item">
          <a href={link.href} class="menu-overlay__link">{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  /* Full-screen white sheet — sits behind the header (z-index 80) */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: var(--base);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 120px var(--scale-7) calc(var(--scale-8) + 80px);
    /* Hidden: clipped fully to the bottom */
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
    visibility: hidden;
  }

  .menu-overlay.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .menu-overlay__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--scale-5);
  }

  .menu-overlay__item {
    overflow: hidden;
  }

  .menu-overlay__link {
    font-size: clamp(var(--scale-7), 7vw, var(--scale-9)); /* 34–89px fluid */
    line-height: 1.1;
    font-weight: 400;
    display: block;
    transition: opacity 0.15s ease;
  }

  .menu-overlay__link:hover {
    opacity: 0.5;
  }

  /* Desktop: hidden */
  @media (min-width: 1024px) {
    .menu-overlay {
      display: none !important;
    }
  }
</style>

<script>
  import { animate } from 'motion';

  function bindMenu() {
    const overlay      = document.getElementById('menu-overlay');
    const toggleBtn    = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const toggleBtnBot = document.getElementById('menu-toggle-bottom') as HTMLButtonElement | null;

    if (!overlay) return;

    const allToggles = [toggleBtn, toggleBtnBot].filter(Boolean) as HTMLButtonElement[];

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      overlay!.classList.add('is-open');
      overlay!.setAttribute('aria-hidden', 'false');
      allToggles.forEach(btn => {
        btn.setAttribute('aria-expanded', 'true');
        btn.textContent = 'Close';
      });
      document.body.style.overflow = 'hidden';

      // Sheet wipes down from top
      animate(
        overlay as Element,
        { clipPath: ['inset(0 0 100% 0)', 'inset(0 0 0% 0)'] },
        { duration: 0.55, easing: [0.22, 1, 0.36, 1] as const }
      );

      // Nav links stagger in
      const links = overlay!.querySelectorAll<HTMLElement>('.menu-overlay__link');
      links.forEach((link, i) => {
        animate(
          link as Element,
          { opacity: [0, 1], y: [16, 0] },
          { duration: 0.4, delay: 0.2 + i * 0.07, easing: [0.22, 1, 0.36, 1] as const }
        );
      });
    }

    function closeMenu() {
      isOpen = false;
      allToggles.forEach(btn => {
        btn.setAttribute('aria-expanded', 'false');
        btn.textContent = 'Other Pages';
      });
      document.body.style.overflow = '';

      // Sheet wipes back up
      animate(
        overlay as Element,
        { clipPath: ['inset(0 0 0% 0)', 'inset(0 0 100% 0)'] },
        { duration: 0.4, easing: [0.4, 0, 0.6, 1] as const }
      );
      setTimeout(() => {
        overlay!.classList.remove('is-open');
        overlay!.setAttribute('aria-hidden', 'true');
      }, 410);
    }

    allToggles.forEach(btn => {
      btn.addEventListener('click', () => {
        isOpen ? closeMenu() : openMenu();
      });
    });

    // Close on nav link click
    overlay.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
  }

  document.addEventListener('astro:page-load', bindMenu);
</script>
