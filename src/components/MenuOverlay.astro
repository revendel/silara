---
/**
 * MenuOverlay component — mobile/tablet only.
 * WordPress equivalent: mobile-menu.php template part.
 *
 * Slides in from the right when the "Other Pages" header button is pressed.
 * Uses Motion One for the open/close animation.
 * Hidden entirely on desktop (≥ 1024 px) via CSS.
 */
const navLinks = [
  { href: '/',            label: 'Vision'      },
  { href: '/mission',     label: 'Mission'     },
  { href: '/our-product', label: 'Our Product' },
  { href: '/the-future',  label: 'The Future'  },
  { href: '/contact',     label: 'Contact'     },
];
---

<div
  class="menu-overlay"
  id="menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div class="menu-overlay__backdrop" id="menu-backdrop"></div>

  <!-- Drawer -->
  <div class="menu-overlay__drawer">
    <button
      class="menu-overlay__close"
      aria-label="Close navigation menu"
      id="menu-close"
    >
      Close
    </button>

    <nav class="menu-overlay__nav" aria-label="Mobile navigation">
      <ul class="menu-overlay__list" role="list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="menu-overlay__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="menu-overlay__footer">
      <ul class="menu-overlay__footer-links" role="list">
        <li><a href="/terms"   class="menu-overlay__footer-link">T&amp;C</a></li>
        <li><a href="/privacy" class="menu-overlay__footer-link">Privacy</a></li>
      </ul>
    </div>
  </div>
</div>

<style>
  /* ── Overlay shell (covers whole viewport) ── */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
  }

  .menu-overlay.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  /* ── Translucent backdrop ── */
  .menu-overlay__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-overlay.is-open .menu-overlay__backdrop {
    opacity: 1;
  }

  /* ── Slide-in drawer ── */
  .menu-overlay__drawer {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 393px;
    height: 100%;
    background-color: var(--base);
    display: flex;
    flex-direction: column;
    padding: var(--scale-7) var(--scale-7) var(--scale-8);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-overlay.is-open .menu-overlay__drawer {
    transform: translateX(0);
  }

  /* ── Close button ── */
  .menu-overlay__close {
    font-size: var(--scale-6);
    align-self: flex-end;
    padding: var(--scale-4);
    color: var(--primary);
    margin-bottom: var(--scale-8);
    transition: opacity 0.15s ease;
  }

  .menu-overlay__close:hover {
    opacity: 0.5;
  }

  /* ── Nav links ── */
  .menu-overlay__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--scale-7);
    flex: 1;
  }

  .menu-overlay__link {
    font-size: var(--scale-8);
    line-height: 1;
    display: block;
    transition: opacity 0.15s ease;
  }

  .menu-overlay__link:hover {
    opacity: 0.5;
  }

  /* ── Footer links inside overlay ── */
  .menu-overlay__footer {
    padding-top: var(--scale-7);
    border-top: var(--scale-2) solid var(--lines);
  }

  .menu-overlay__footer-links {
    list-style: none;
    display: flex;
    gap: var(--scale-6);
  }

  .menu-overlay__footer-link {
    font-size: var(--scale-6);
    transition: opacity 0.15s ease;
  }

  .menu-overlay__footer-link:hover {
    opacity: 0.5;
  }

  /* ── Desktop: hide entirely ── */
  @media (min-width: 1024px) {
    .menu-overlay {
      display: none !important;
    }
  }
</style>

<script>
  import { animate } from 'motion';

  function bindMenu() {
    const overlay    = document.getElementById('menu-overlay');
    const toggleBtn  = document.getElementById('menu-toggle');
    const closeBtn   = document.getElementById('menu-close');
    const backdrop   = document.getElementById('menu-backdrop');

    if (!overlay || !toggleBtn) return;

    function openMenu() {
      overlay!.classList.add('is-open');
      overlay!.setAttribute('aria-hidden', 'false');
      toggleBtn!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';

      // Stagger-animate nav links with Motion One
      const links = overlay!.querySelectorAll('.menu-overlay__link');
      animate(
        links,
        { opacity: [0, 1], x: [20, 0] },
        { duration: 0.4, delay: (_el: Element, i: number) => 0.15 + i * 0.05, easing: [0.4, 0, 0.2, 1] }
      );
    }

    function closeMenu() {
      overlay!.classList.remove('is-open');
      overlay!.setAttribute('aria-hidden', 'true');
      toggleBtn!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggleBtn.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    // Close and navigate on link click
    overlay.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  // Bind on first load and after every View Transition navigation
  document.addEventListener('astro:page-load', () => {
    bindMenu();
  });
</script>
