---
/**
 * BaseLayout — HTML shell for every page.
 * WordPress equivalent: functions.php + get_header() / get_footer() wrappers.
 */
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MenuOverlay from '../components/MenuOverlay.astro';
import Logo from '../components/Logo.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  keywords?: string;
  robots?: string;
}

const {
  title,
  description = 'Silara SuperFoods — nutrient-dense superfoods built for modern life.',
  ogImage = '/images/og-default.webp',
  keywords,
  robots,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL   = new URL(ogImage, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    {robots && <meta name="robots" content={robots} />}

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/PPNeueMontreal-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/PPNeueMontreal-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={`${title} — Silara SuperFoods`} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:type"        content="website" />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:site_name"   content="Silara SuperFoods" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={`${title} — Silara SuperFoods`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title} — Silara SuperFoods</title>

    <!-- Astro View Transitions: client-side routing + smooth page transitions -->
    <ClientRouter />

    <!-- Per-page head additions (JSON-LD, extra meta, etc.) -->
    <slot name="head" />

    <!-- Hotjar Tracking Code for Silara SuperFoods -->
    <script is:inline>
      (function(h,o,t,j,a,r){
        h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};
        h._hjSettings={hjid:6675116,hjsv:6};
        a=o.getElementsByTagName('head')[0];
        r=o.createElement('script');r.async=1;
        r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;
        a.appendChild(r);
      })(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
    </script>
  </head>

  <body>
    <div class="page">
      <!-- WordPress: get_header() -->
      <Header />

      <!-- WordPress: the_content() / page template -->
      <main class="page__main" id="main-content">
        <slot />
      </main>

      <!-- WordPress: get_footer() -->
      <Footer />
    </div>

    <!-- Mobile / tablet slide-in nav overlay -->
    <MenuOverlay />

    <!-- Mobile bottom nav bar: logo icon left, pill button right -->
    <div class="mobile-bottom-nav">
      <Logo variant="inactive" />
      <button
        class="mobile-bottom-nav__btn"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="menu-overlay"
        id="menu-toggle-bottom"
      >
        Menu
      </button>
    </div>

    <script>
      import { fadeIn, lineDraw, prefersReducedMotion } from '../utils/animations';

      document.addEventListener('astro:page-load', () => {
        if (prefersReducedMotion()) return;

        const main = document.getElementById('main-content');
        if (main) fadeIn(main, { duration: 0.4, delay: 0 });

        const headerLine = document.querySelector<HTMLElement>('header [data-line]');
        if (headerLine) lineDraw(headerLine, { duration: 1.0, delay: 0 });
      });
    </script>
  </body>
</html>
